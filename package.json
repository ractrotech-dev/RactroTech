{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit introspect --out ./utils/db/introspected",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stripe:setup": "tsx --env-file=.env stripeSetup.ts",
    "stripe:listen": "stripe listen --forward-to localhost:3000/webhook/stripe",
    "library:generate": "tsx scripts/component-library/generate.ts",
    "library:migrate": "tsx --env-file=.env scripts/component-library/seed/apply-migration.ts",
    "library:seed:categories": "tsx --env-file=.env scripts/component-library/seed/seed-categories.ts",
    "library:seed:batch": "tsx --env-file=.env scripts/component-library/seed/seed-components.ts",
    "library:seed:all": "tsx --env-file=.env scripts/component-library/seed/seed-components.ts",
    "library:dedup:scan": "tsx --env-file=.env scripts/component-library/dedup/scan-duplicates.ts",
    "library:dedup:scan:apply": "tsx --env-file=.env scripts/component-library/dedup/scan-duplicates.ts --apply",
    "library:dedup:replace": "tsx --env-file=.env scripts/component-library/dedup/replace-duplicates.ts",
    "library:dedup:replace:apply": "tsx --env-file=.env scripts/component-library/dedup/replace-duplicates.ts --apply",
    "library:dedup:cleanup": "tsx --env-file=.env scripts/component-library/dedup/cleanup-duplicates.ts",
    "library:dedup:cleanup:apply": "tsx --env-file=.env scripts/component-library/dedup/cleanup-duplicates.ts --apply"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.24.2",
    "drizzle-orm": "^0.33.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.428.0",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.4",
    "react": "^18",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18",
    "react-hook-form": "^7.76.1",
    "react-icons": "^5.3.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "stripe": "^16.9.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.8",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.4.5",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
