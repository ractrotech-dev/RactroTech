# PLACE YOUR SUPABASE PROJECT URL AND ANON KEY HERE
NEXT_PUBLIC_SUPABASE_URL=xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
# Canonical site URL (use one host: www or non-www). Both vars are supported; SITE_URL takes precedence.
NEXT_PUBLIC_SITE_URL=https://www.ractrotech.com
NEXT_PUBLIC_WEBSITE_URL=https://www.ractrotech.com

# Optional: server-only — never expose to the browser or prefix with NEXT_PUBLIC_.
# Used for Storage uploads on /review (create public bucket "review-uploads").
SUPABASE_SERVICE_ROLE_KEY=

# Auth hardening (configure in Supabase Dashboard → Authentication → Settings):
# - Enable "Confirm email" for signups
# - Set Site URL to NEXT_PUBLIC_WEBSITE_URL (logo + links in auth emails use {{ .SiteURL }})
# - Paste HTML from supabase/email-templates/ into Authentication → Email Templates
# - Enable "Leaked password protection" (HaveIBeenPwned) under Password Security
# - JWT expiry: 3600s (1 hour access token; refresh handled by middleware)
# - Password recovery / OTP expiry: 3600s (1 hour)
# - Enable refresh token rotation
# DB linter fixes: run utils/db/migrations/manual_supabase_security_linter_fixes.sql in SQL Editor
# OAuth secrets (GOOGLE_OAUTH_*, GITHUB_*, etc.) belong in Supabase provider settings, not in client env.

# Optional: Google Business “Write a review” URL (shown on /review). Must be https.
NEXT_PUBLIC_GOOGLE_REVIEW_URL=

# PLACE YOUR POSTGRES DATABBASE UEL AND PASSWORD HERE
DATABASE_URL=xxxxx

# Drizzle migrations (`npm run db:migrate`) use `drizzle.config.ts` and read DIRECT_URL. For Supabase, use the
# direct (non-pooler) connection string, or set DIRECT_URL to the same value as DATABASE_URL for local dev.
DIRECT_URL=xxxxx

# Optional: set to "false" if db:migrate fails with SELF_SIGNED_CERT_IN_CHAIN (auto-enabled for *.supabase.co URLs)
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Pull current DB schema into TypeScript (Drizzle introspect): `npm run db:pull` — writes to utils/db/introspected/
# (does not overwrite utils/db/schema.ts). Requires DIRECT_URL to reach Postgres.

# PLACE YOUR GOOGLE CLIENT ID AND SECRET HERE TO ENABLE OAUTH SOCIAL LOGIN (https://supabase.com/docs/guides/auth/social-login/auth-google)
GOOGLE_OAUTH_CLIENT_ID=xxxxx
GOOGLE_OAUTH_CLIENT_SECRET=xxxxx

# Place GITHUB client id and secret to easily enable github oauth login
GITHUB_OAUTH_CLIENT_ID=xxxxx
GITHUB_OAUTH_CLIENT_SECRET=xxxxx
# STRIPE PRICING TABLE PUBLIC KEY AND API
NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxx

# Admin: comma-separated emails that get super_admin on first sync (and promote from user → super_admin when listed).
# Also set role in users_table manually if you prefer (admin, manager, developer, super_admin).
ADMIN_BOOTSTRAP_EMAILS=admin@test.com

# Local dev only (NODE_ENV=development): comma-separated emails that may open /admin without an admin role in DB.
# Remove in production. Prefer ADMIN_BOOTSTRAP_EMAILS + DATABASE_URL for real RBAC.
ADMIN_DEV_ACCESS_EMAILS=admin@test.com

# ─── Security & deployment ───────────────────────────────────────────────────
# NEVER prefix secrets with NEXT_PUBLIC_. Server-only: STRIPE_SECRET_KEY, SUPABASE_SERVICE_ROLE_KEY,
# DATABASE_URL, DIRECT_URL, RESEND_API_KEY, *_OAUTH_CLIENT_SECRET.
#
# Database: use Supabase connection pooler for DATABASE_URL; use direct URL only for migrations (DIRECT_URL).
# In Supabase Dashboard → Database Settings: restrict direct connections; rely on pooler + RLS for app access.
#
# Run before deploy: npm run security:check-secrets
# Production logs: auth attempts, rate limits, and API errors emit JSON to stdout (ingest via Vercel/Datadog).
#
# Optional: DATABASE_SSL_REJECT_UNAUTHORIZED=false (only if migrate fails with cert errors locally)
